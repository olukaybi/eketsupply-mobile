# ──────────────────────────────────────────────────────────────────────────────
# CODEOWNERS — EketSupply Mobile
#
# Defines who is automatically requested to review PRs based on file paths.
# Rules are matched from bottom to top; the last matching rule wins.
# Syntax: <pattern> <@github-username or @org/team>
#
# Replace placeholder usernames with real GitHub handles before committing.
# ──────────────────────────────────────────────────────────────────────────────

# ── Default owner (catches everything not matched below) ──────────────────────
*                               @eketsupply/core-team

# ── Mobile app screens & components ──────────────────────────────────────────
/app/**                         @eketsupply/mobile-team
/components/**                  @eketsupply/mobile-team
/hooks/**                       @eketsupply/mobile-team

# ── Server / API layer ────────────────────────────────────────────────────────
/server/**                      @eketsupply/backend-team
/drizzle/**                     @eketsupply/backend-team
/shared/**                      @eketsupply/backend-team

# ── CI / DevOps ───────────────────────────────────────────────────────────────
/.github/**                     @eketsupply/devops-team

# ── Dependency manifests (Dependabot PRs routed here) ────────────────────────
/package.json                   @eketsupply/devops-team
/pnpm-lock.yaml                 @eketsupply/devops-team

# ── Theme & design tokens ─────────────────────────────────────────────────────
/theme.config.js                @eketsupply/mobile-team
/tailwind.config.js             @eketsupply/mobile-team
/global.css                     @eketsupply/mobile-team

# ── Tests ─────────────────────────────────────────────────────────────────────
/tests/**                       @eketsupply/core-team
/app/**/*.test.tsx               @eketsupply/core-team
/lib/**/*.test.ts                @eketsupply/core-team
